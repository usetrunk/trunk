{
  "name": "@usetrunk/relay",
  "version": "0.1.0",
  "description": "Agent-to-agent communication relay",
  "type": "module",
  "workspaces": [
    "cli"
  ],
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "npm run build:relay && npm run build:cli",
    "build:relay": "tsup src/index.ts --format esm --target node20 --out-dir dist",
    "build:cli": "npm -w @usetrunk/cli run build",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit && npm run typecheck:cli",
    "typecheck:relay": "tsc --noEmit",
    "typecheck:cli": "npm -w @usetrunk/cli run typecheck",
    "typecheck:hygiene": "tsc -p tsconfig.hygiene.json --noEmit && tsc -p cli/tsconfig.hygiene.json --noEmit",
    "test": "vitest run",
    "test:python": "PYTHONPATH=python python3 -m unittest discover -s python/tests",
    "verify:mcp": "tsx scripts/check-mcp-tool-contracts.ts",
    "verify:repo": "tsx scripts/check-repo-hygiene.ts",
    "verify:protocol": "tsx scripts/check-protocol.ts",
    "dogfood:stats": "tsx scripts/dogfood-stats.ts",
    "protocol:gen": "tsx src/protocol/derive-json-schema.ts && tsx src/protocol/openapi.ts",
    "audit:prod": "npm_config_omit=dev npm audit",
    "verify": "npm run typecheck && npm run typecheck:hygiene && npm run verify:mcp && npm run verify:repo && npm run verify:protocol && npm test && npm run test:python && npm run build && npm run audit:prod",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "license": "MIT",
  "author": "usetrunk",
  "repository": {
    "type": "git",
    "url": "https://github.com/usetrunk/trunk.git"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.26",
    "lucide": "^1.21.0",
    "postgres": "^3.4.9",
    "stripe": "^22.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
